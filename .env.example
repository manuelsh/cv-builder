# Copy this file to .env and fill in your values

# AWS Bedrock Configuration
AWS_REGION=eu-west-1
AWS_PROFILE=claude

# Model ARNs - get these from your AWS Bedrock console
BEDROCK_MODEL_FAST=
BEDROCK_MODEL_BEST=

# Optional backend selection (defaults to litellm)
CV_BUILDER_LLM_BACKEND=litellm

# Codex SDK configuration
CODEX_MODEL_FAST=
CODEX_MODEL_BEST=
CODEX_NODE_BIN=node

# Google Drive OAuth Credentials (JSON string from Google Cloud Console)
# Alternative: place credentials.json in ~/.cv-builder/ or project root
GOOGLE_DRIVE_OAUTH_CREDENTIALS=
